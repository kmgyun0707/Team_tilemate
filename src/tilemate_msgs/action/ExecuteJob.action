# goal
string token                 # 작업 ID (job 식별자)
int32[] design_layout        # 타일 배치 타입 배열 (예: [1,1,1,2,2,...])
bool is_resume               # 작업 재개 여부
int32 completed_jobs         # 완료된 타일 수
int32 current_step           # 현재 타일 작업 단계
int32 current_tile_index     # 현재 작업 중인 타일 번호

---
# result
bool success                 # 작업 성공 여부
string message               # 결과 메시지

---
# feedback
int32 overall_step           # 전체 공정 단계
float32 overall_progress     # 전체 공정 진행도 (0~1)
int32 tile_index             # 현재 타일 번호
int32 tile_type              # 현재 타일 타입
int32 tile_step              # 타일 내부 작업 단계
float32 tile_progress        # 타일 작업 진행도 (0~1)
string state                 # 현재 상태 설명